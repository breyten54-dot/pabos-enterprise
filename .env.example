# PABOS Enterprise — root environment template
# Copy this file to .env and fill in real values locally. Never commit .env.

# Application
NODE_ENV=development
APP_NAME=PABOS Enterprise
APP_PORT=4000
APP_URL=http://localhost
API_BASE_URL=http://localhost:4000/api/v1

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=pabos
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pabos_dev
# Use 5432 for the Docker Compose Postgres, 5433 for the local portable Postgres.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET_PREFIX=pabos

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# JWT / Authentication
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=pabos-enterprise

# MFA (TOTP)
MFA_ISSUER=PABOS Enterprise
MFA_ENFORCE_FOR_ROLES=admin,compliance_officer

# SMTP / Email notifications
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@praeto.example
SMTP_PASSWORD=changeme
SMTP_FROM_NAME=PABOS Enterprise
SMTP_FROM_ADDRESS=notifications@praeto.example
