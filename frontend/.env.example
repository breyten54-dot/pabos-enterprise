# PABOS Enterprise — frontend environment template
# Copy this file to .env and fill in real values locally. Never commit .env.

# Vite environment variables must be prefixed with VITE_.

NODE_ENV=development
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_APP_NAME=PABOS Enterprise
VITE_APP_URL=http://localhost

# Optional: feature flags for early development.
VITE_ENABLE_AI_INTAKE=true
VITE_ENABLE_MFA=true
